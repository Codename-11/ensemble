# Agent-Forge configuration
# Copy to .env and adjust values for your environment.

# Server
AGENT_FORGE_PORT=23000
# AGENT_FORGE_CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# URLs
# AGENT_FORGE_URL=http://localhost:23000

# Data and agent config
# AGENT_FORGE_DATA_DIR=~/.agent-forge
# AGENT_FORGE_AGENTS_CONFIG=./agents.json
# AGENT_FORGE_AGENT_FLAGS=

# Watchdog
# AGENT_FORGE_WATCHDOG_NUDGE_MS=90000
# AGENT_FORGE_WATCHDOG_STALL_MS=180000

# Telegram notifications (optional)
# ENSEMBLE_TELEGRAM_BOT_TOKEN=
# ENSEMBLE_TELEGRAM_CHAT_ID=

# Metadata
# ENSEMBLE_PROJECT=
# ENSEMBLE_CREATED_BY=
