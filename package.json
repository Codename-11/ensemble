{
  "name": "agent-forge",
  "version": "1.0.0",
  "description": "Agent-Forge — Multi-agent collaboration engine. Deploy AI agent teams, watch them work in real-time.",
  "type": "module",
  "bin": {
    "agent-forge": "./cli/agent-forge.ts"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "tsx server.ts",
    "dev:web": "cd web && npm run dev",
    "start": "tsx server.ts",
    "build": "tsc --noEmit",
    "build:web": "cd web && npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "monitor": "tsx cli/monitor.ts --latest",
    "cli": "tsx cli/agent-forge.ts",
    "launch": "node scripts/collab-launch.mjs",
    "bridge": "node scripts/agent-forge-bridge.mjs",
    "setup": "node scripts/setup-claude-code.mjs",
    "mcp:install": "node scripts/mcp-install.mjs install",
    "mcp:uninstall": "node scripts/mcp-install.mjs uninstall",
    "mcp:status": "node scripts/mcp-install.mjs status",
    "test": "vitest run",
    "postinstall": "cd web && npm install --ignore-scripts 2>/dev/null || true"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "tsx": "^4.0.0",
    "uuid": "^9.0.0",
    "ws": "^8.20.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
